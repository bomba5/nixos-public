    "exec": "date '+ %H:%M:%S ┬╗ '",
    "interval": 1
  },
  "custom/date": {
    "format": "{}",
    "tooltip": false,
    "exec": "date '+%A, %d %B (CW%V) '",
    "interval": 60,
    "class": "hidden-date"
  },

