  "reload_style_on_change": true,

  "modules-left": [
    "group/clock",
    "hyprland/workspaces"
  ],
  "modules-right": [
    "group/group-power",
    "group/hardware",
    "pulseaudio"
  ],

  "group/group-power": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 500,
      "children-class": "not-power",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/power",
      "custom/quit",
      "custom/lock",
      "custom/reboot",
      "battery"
    ]
  },

  "custom/power": {
    "format": " ’Ćæ ",
    "tooltip": false,
    "on-click": "shutdown now"
