      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": [
      "memory",
      "cpu",
      "temperature",
      "network",
      "bluetooth"
    ]
  },

  "group/clock": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 500,
      "children-class": "not-time",
      "transition-left-to-right": true
    },
    "modules": [
      "custom/time",
      "custom/date"
